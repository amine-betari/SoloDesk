{% extends 'base.html.twig' %}

{% block title %}{{ 'error.404_title'|trans }}{% endblock %}

{% block body %}
    <section class="px-6 py-16">
        <div class="mx-auto max-w-2xl rounded-2xl border border-[#2A3747] bg-[#1F2732] p-8 text-center shadow-xl">
            <div class="text-sm font-semibold uppercase tracking-[0.25em] text-blue-300">404</div>
            <h1 class="mt-3 text-3xl font-bold text-white">{{ 'error.404_heading'|trans }}</h1>
            <p class="mt-3 text-gray-300">{{ 'error.404_text'|trans }}</p>
            <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
                <a href="{{ path('home') }}" class="rounded-lg bg-blue-600 px-5 py-2.5 font-semibold text-white hover:bg-blue-700">{{ 'error.back_home'|trans }}</a>
                <a href="{{ path('app_search') }}" class="rounded-lg bg-[#223044] px-5 py-2.5 font-semibold text-white hover:bg-[#2E415B]">{{ 'error.search'|trans }}</a>
            </div>
        </div>
    </section>
{% endblock %}
