{% extends 'base.html.twig' %}

{% block title %}{{ 'help.faq_title'|trans }}{% endblock %}

{% block body %}
    <section class="px-6 py-8">
        <div class="max-w-4xl mx-auto">
            <div class="bg-[#1F2732] border border-[#2A3747] rounded-xl p-6 md:p-8">
                <h1 class="text-3xl md:text-4xl font-bold text-white mb-3">
                    {{ 'help.faq_heading'|trans }}
                </h1>
                <p class="text-gray-300 text-lg leading-relaxed">
                    {{ 'help.faq_intro'|trans }}
                </p>

                <div class="mt-8">
                    <h2 class="text-2xl font-semibold text-white">{{ 'help.workflow_title'|trans }}</h2>
                    <p class="mt-2 text-gray-300">{{ 'help.workflow_intro'|trans }}</p>
                    <div class="mt-5 grid gap-4 md:grid-cols-3">
                        {% for step, route in {1: 'app_company_edit', 2: 'app_client_new', 3: 'app_estimate_new'} %}
                            <a href="{{ path(route) }}" class="rounded-lg border border-[#2A3747] bg-[#16202A] p-5 transition hover:border-blue-500">
                                <div class="text-xs font-semibold uppercase tracking-wider text-blue-300">{{ ('help.workflow_step_' ~ step)|trans }}</div>
                                <div class="mt-2 font-semibold text-white">{{ ('help.workflow_step_' ~ step ~ '_title')|trans }}</div>
                                <div class="mt-2 text-sm text-gray-400">{{ ('help.workflow_step_' ~ step ~ '_text')|trans }}</div>
                            </a>
                        {% endfor %}
                    </div>
                </div>

                <div class="mt-8 rounded-lg border border-blue-700/50 bg-blue-950/30 p-5">
                    <h2 class="text-xl font-semibold text-blue-200">{{ 'help.convert_title'|trans }}</h2>
                    <p class="mt-2 text-gray-300">{{ 'help.convert_text'|trans }}</p>
                </div>

                <div class="mt-8 grid gap-6">
                    <div class="bg-[#16202A] border border-[#2A3747] rounded-lg p-5">
                        <h2 class="text-xl font-semibold text-white mb-2">{{ 'help.estimation_title'|trans }}</h2>
                        <p class="text-gray-300 leading-relaxed">
                            {{ 'help.estimation_text'|trans|raw }}
                        </p>
                        <ul class="mt-3 text-gray-300 list-disc list-inside">
                            <li>{{ 'help.estimation_point1'|trans }}</li>
                            <li>{{ 'help.estimation_point2'|trans }}</li>
                            <li>{{ 'help.estimation_point3'|trans }}</li>
                        </ul>
                    </div>

                    <div class="bg-[#16202A] border border-[#2A3747] rounded-lg p-5">
                        <h2 class="text-xl font-semibold text-white mb-2">{{ 'help.estimate_title'|trans }}</h2>
                        <p class="text-gray-300 leading-relaxed">
                            {{ 'help.estimate_text'|trans|raw }}
                        </p>
                        <ul class="mt-3 text-gray-300 list-disc list-inside">
                            <li>{{ 'help.estimate_point1'|trans }}</li>
                            <li>{{ 'help.estimate_point2'|trans }}</li>
                            <li>{{ 'help.estimate_point3'|trans }}</li>
                        </ul>
                    </div>

                    <div class="bg-[#16202A] border border-[#2A3747] rounded-lg p-5">
                        <h2 class="text-xl font-semibold text-white mb-2">{{ 'help.invoice_title'|trans }}</h2>
                        <p class="text-gray-300 leading-relaxed">
                            {{ 'help.invoice_text'|trans|raw }}
                        </p>
                        <ul class="mt-3 text-gray-300 list-disc list-inside">
                            <li>{{ 'help.invoice_point1'|trans }}</li>
                            <li>{{ 'help.invoice_point2'|trans }}</li>
                            <li>{{ 'help.invoice_point3'|trans }}</li>
                        </ul>
                    </div>
                </div>

                <div class="mt-8 bg-[#16202A] border border-[#2A3747] rounded-lg p-5">
                    <h2 class="text-xl font-semibold text-white mb-2">{{ 'help.summary_title'|trans }}</h2>
                    <p class="text-gray-300 leading-relaxed">
                        {{ 'help.summary_text'|trans|raw }}
                    </p>
                </div>

                <div class="mt-8">
                    <h2 class="text-2xl font-semibold text-white">{{ 'help.personas_title'|trans }}</h2>
                    <div class="mt-5 grid gap-4 md:grid-cols-3">
                        {% for persona in ['simple', 'project', 'service'] %}
                            <div class="rounded-lg border border-[#2A3747] bg-[#16202A] p-5">
                                <div class="font-semibold text-white">{{ ('help.persona_' ~ persona ~ '_title')|trans }}</div>
                                <p class="mt-2 text-sm leading-relaxed text-gray-300">{{ ('help.persona_' ~ persona ~ '_text')|trans }}</p>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
