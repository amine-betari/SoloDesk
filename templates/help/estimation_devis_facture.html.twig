{% extends 'base.html.twig' %}

{% block title %}{{ 'help.faq_title'|trans }}{% endblock %}

{% block body %}
    <section class="px-6 py-8">
        <div class="max-w-4xl mx-auto">
            <div class="bg-[#1F2732] border border-[#2A3747] rounded-xl p-6 md:p-8">
                <h1 class="text-3xl md:text-4xl font-bold text-white mb-3">
                    {{ 'help.faq_heading'|trans }}
                </h1>
                <p class="text-gray-300 text-lg leading-relaxed">
                    {{ 'help.faq_intro'|trans }}
                </p>

                <div class="mt-8 grid gap-6">
                    <div class="bg-[#16202A] border border-[#2A3747] rounded-lg p-5">
                        <h2 class="text-xl font-semibold text-white mb-2">{{ 'help.estimation_title'|trans }}</h2>
                        <p class="text-gray-300 leading-relaxed">
                            {{ 'help.estimation_text'|trans|raw }}
                        </p>
                        <ul class="mt-3 text-gray-300 list-disc list-inside">
                            <li>{{ 'help.estimation_point1'|trans }}</li>
                            <li>{{ 'help.estimation_point2'|trans }}</li>
                            <li>{{ 'help.estimation_point3'|trans }}</li>
                        </ul>
                    </div>

                    <div class="bg-[#16202A] border border-[#2A3747] rounded-lg p-5">
                        <h2 class="text-xl font-semibold text-white mb-2">{{ 'help.estimate_title'|trans }}</h2>
                        <p class="text-gray-300 leading-relaxed">
                            {{ 'help.estimate_text'|trans|raw }}
                        </p>
                        <ul class="mt-3 text-gray-300 list-disc list-inside">
                            <li>{{ 'help.estimate_point1'|trans }}</li>
                            <li>{{ 'help.estimate_point2'|trans }}</li>
                            <li>{{ 'help.estimate_point3'|trans }}</li>
                        </ul>
                    </div>

                    <div class="bg-[#16202A] border border-[#2A3747] rounded-lg p-5">
                        <h2 class="text-xl font-semibold text-white mb-2">{{ 'help.invoice_title'|trans }}</h2>
                        <p class="text-gray-300 leading-relaxed">
                            {{ 'help.invoice_text'|trans|raw }}
                        </p>
                        <ul class="mt-3 text-gray-300 list-disc list-inside">
                            <li>{{ 'help.invoice_point1'|trans }}</li>
                            <li>{{ 'help.invoice_point2'|trans }}</li>
                            <li>{{ 'help.invoice_point3'|trans }}</li>
                        </ul>
                    </div>
                </div>

                <div class="mt-8 bg-[#16202A] border border-[#2A3747] rounded-lg p-5">
                    <h2 class="text-xl font-semibold text-white mb-2">{{ 'help.summary_title'|trans }}</h2>
                    <p class="text-gray-300 leading-relaxed">
                        {{ 'help.summary_text'|trans|raw }}
                    </p>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
