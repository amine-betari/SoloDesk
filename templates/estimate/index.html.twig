{% extends 'base.html.twig' %}

{% block title %}{{ 'estimate.list_title'|trans }}{% endblock %}

{% block body %}
    <div class="w-full px-6 py-8">
        <div class="space-y-6">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <h1 class="text-3xl sm:text-4xl font-bold text-white">{{ 'estimate.title'|trans }}</h1>
                    <p class="text-sm text-gray-400 mt-2">{{ 'estimate.subtitle'|trans }}</p>
                </div>
                <div class="flex items-center gap-3">
                    <a href="{{ path('app_estimate_new') }}"
                       class="inline-flex items-center justify-center px-5 py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold rounded-lg transition-colors btn-mobile">
                        {{ 'estimate.new'|trans }}
                    </a>
                </div>
            </div>

            <div class="rounded-2xl border border-[#2A3747] bg-[#1F2732] p-5">
                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
                    <div>
                        <div class="text-xs uppercase tracking-wider text-gray-400">{{ 'common.total'|trans }}</div>
                        <div class="mt-2 text-2xl font-semibold text-white">{{ pagination.total }}</div>
                    </div>
                    <div>
                        <div class="text-xs uppercase tracking-wider text-gray-400">{{ 'estimate.count_shown'|trans }}</div>
                        <div class="mt-2 text-2xl font-semibold text-white">{{ pagination.items|length }}</div>
                    </div>
                    <div>
                        <div class="text-xs uppercase tracking-wider text-gray-400">{{ 'common.page'|trans }}</div>
                        <div class="mt-2 text-2xl font-semibold text-white">{{ pagination.page }} / {{ pagination.pages }}</div>
                    </div>
                    <div>
                        <div class="text-xs uppercase tracking-wider text-gray-400">{{ 'estimate.displayed_total'|trans }}</div>
                        <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm font-semibold text-white">
                            {% for currency, total in displayedTotals %}
                                <span>{{ total|format_currency(currency) }}</span>
                            {% else %}
                                <span>{{ 'common.dash'|trans }}</span>
                            {% endfor %}
                        </div>
                    </div>
                </div>
                <div class="mt-5 border-t border-[#2A3747] pt-4">
                    <div class="text-xs uppercase tracking-wider text-gray-400 mb-3">{{ 'estimate.status_summary'|trans }}</div>
                    <div class="flex flex-wrap gap-2">
                        {% for status, count in statusCounts %}
                            <span class="rounded-full bg-[#111922] border border-[#2A3747] px-3 py-1 text-xs font-semibold text-gray-200">
                                {{ status|trans }} : {{ count }}
                            </span>
                        {% endfor %}
                    </div>
                </div>
            </div>

            {% include 'components/_filter_project_estimate_form.html.twig' with {'form': filterForm, 'action': path('app_estimate_index') } %}

            {% if pagination.items is not empty %}
                <div class="overflow-x-auto table-responsive rounded-2xl border border-gray-200 bg-white shadow-lg">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'estimate.table_estimate'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 hidden md:table-cell">{{ 'estimate.table_client'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'estimate.table_amount'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'estimate.table_status'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 hidden lg:table-cell">{{ 'estimate.table_start'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 hidden lg:table-cell">{{ 'estimate.table_project'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'table.actions'|trans }}</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                        {% for estimate in pagination.items %}
                            {% set canDelete = estimate.canBeDeleted %}
                            <tr class="hover:bg-gray-50 transition-colors cursor-pointer"
                                tabindex="0"
                                role="link"
                                onclick="if (!event.target.closest('a, button, summary, details, form')) window.location.href='{{ path('app_estimate_show', {'id': estimate.id}) }}'"
                                onkeydown="if ((event.key === 'Enter' || event.key === ' ') && !event.target.closest('a, button, summary, details, form')) { event.preventDefault(); window.location.href='{{ path('app_estimate_show', {'id': estimate.id}) }}'; }">
                                <td class="px-6 py-4">
                                    <div class="min-w-0">
                                        <a href="{{ path('app_estimate_show', {'id': estimate.id}) }}"
                                           class="text-sm font-semibold text-gray-900 hover:text-blue-600 transition-colors">
                                            {{ estimate.name }}
                                        </a>
                                        <div class="text-xs text-gray-500">#{{ estimate.estimateNumber }}</div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600 hidden md:table-cell">{{ estimate.client ? estimate.client.name : 'common.dash'|trans }}</td>
                                <td class="px-6 py-4 text-sm text-gray-700">
                                    {{ estimate.amount|format_currency(estimate.currency, app.request.locale ?: 'fr_FR') }}
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    {% set color =
                                        estimate.status == 'draft' ? 'gray' :
                                        estimate.status == 'sent' ? 'indigo' :
                                        estimate.status == 'accepted' ? 'green' :
                                        estimate.status == 'rejected' ? 'red' :
                                        estimate.status == 'expired' ? 'amber' : 'gray'
                                    %}
                                    <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-{{ color }}-100 text-{{ color }}-800">
                                        {{ estimate.status|trans }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600 hidden lg:table-cell">
                                    {{ estimate.startDate ? estimate.startDate|date('d/m/Y') : 'common.dash'|trans }}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600 hidden lg:table-cell">
                                    {% if estimate.project %}
                                        <a href="{{ path('app_project_show', {'id': estimate.project.id}) }}" class="text-blue-600 hover:text-blue-500">
                                            {{ estimate.project }}
                                        </a>
                                    {% else %}
                                        {{ 'common.dash'|trans }}
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <details class="relative">
                                        <summary class="list-none inline-flex cursor-pointer items-center gap-2 px-3 py-1.5 text-xs font-semibold rounded bg-gray-100 text-gray-700 hover:bg-gray-200 transition">
                                            {{ 'table.actions'|trans }}
                                        </summary>
                                        <div class="absolute right-0 mt-2 z-10 w-56 rounded-lg border border-gray-200 bg-white shadow-lg p-2 flex flex-col gap-2">
                                            <a href="{{ path('app_estimate_edit', {'id': estimate.id}) }}"
                                               class="px-3 py-2 rounded bg-blue-600 text-white text-xs font-semibold hover:bg-blue-700 transition">
                                                {{ 'actions.edit'|trans }}
                                            </a>
                                            {{ include('estimate/_delete_form.html.twig', {estimate: estimate, canDelete: canDelete}) }}
                                        </div>
                                    </details>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="px-6 py-10 text-center text-gray-400">{{ 'estimate.none'|trans }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>

                <div class="flex flex-wrap items-center justify-between gap-4">
                    <p class="text-sm text-gray-400">
                        {{ 'estimate.pagination'|trans({'%count%': pagination.items|length, '%total%': pagination.total}) }}
                    </p>
                    <div class="flex flex-wrap gap-2">
                        {% for i in 1..pagination.pages %}
                            <a href="{{ path('app_estimate_index', {page: i}) }}"
                               class="px-3 py-1.5 rounded-lg text-sm font-medium {{ i == pagination.page ? 'bg-blue-600 text-white' : 'bg-[#223044] text-gray-200 hover:bg-[#2E415B]' }}">
                                {{ i }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% else %}
                <div class="rounded-2xl border border-dashed border-[#2A3747] bg-[#111922] p-10 text-center">
                    <p class="text-gray-400 mb-4">{{ 'estimate.none'|trans }}</p>
                    <a href="{{ path('app_estimate_new') }}"
                       class="inline-flex items-center justify-center px-5 py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold rounded-lg transition-colors btn-mobile">
                        {{ 'estimate.create_first'|trans }}
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
