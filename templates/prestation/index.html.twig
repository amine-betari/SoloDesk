{% extends 'base.html.twig' %}

{% block title %}{{ 'prestation.title'|trans }}{% endblock %}

{% block body %}
    <div class="w-full px-6 py-8">
        <div class="space-y-6">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <h1 class="text-3xl sm:text-4xl font-bold text-white">{{ 'prestation.title'|trans }}</h1>
                    <p class="text-sm text-gray-400 mt-2">{{ 'prestation.subtitle'|trans }}</p>
                </div>
                <div class="flex items-center gap-3">
                    <div class="hidden sm:flex items-center gap-2 rounded-full bg-[#1F2732] border border-[#2A3747] px-4 py-2 text-sm text-gray-300">
                        <span class="text-gray-500">{{ 'common.total'|trans }}</span>
                        <span class="text-white font-semibold">{{ pagination.total }}</span>
                    </div>
                    <a href="{{ path('app_prestation_new') }}"
                       class="inline-flex items-center justify-center px-5 py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold rounded-lg transition-colors btn-mobile">
                        {{ 'prestation.new'|trans }}
                    </a>
                </div>
            </div>

            <div class="bg-[#1F2732] border border-[#2A3747] rounded-2xl p-4">
                <form method="get" class="grid grid-cols-1 md:grid-cols-3 gap-3 md:items-center">
                    <input
                        type="text"
                        name="q"
                        value="{{ q }}"
                        placeholder="{{ 'prestation.search_placeholder'|trans }}"
                        class="w-full rounded-md border border-[#2A3747] bg-[#111922] text-gray-100 placeholder-gray-500 px-4 py-2"
                    />
                    <select name="status" class="w-full rounded-md border border-[#2A3747] bg-[#111922] text-gray-100 px-4 py-2">
                        <option value="">{{ 'common.all'|trans }}</option>
                        <option value="draft" {{ status == 'draft' ? 'selected' : '' }}>{{ 'prestation.status_draft'|trans }}</option>
                        <option value="invoiced" {{ status == 'invoiced' ? 'selected' : '' }}>{{ 'prestation.status_invoiced'|trans }}</option>
                        <option value="paid" {{ status == 'paid' ? 'selected' : '' }}>{{ 'prestation.status_paid'|trans }}</option>
                    </select>
                    <select name="collaborator" class="w-full rounded-md border border-[#2A3747] bg-[#111922] text-gray-100 px-4 py-2">
                        <option value="">{{ 'prestation.filter_collaborator'|trans }}</option>
                        {% for collaborator in collaborators %}
                            <option value="{{ collaborator.id }}" {{ collaboratorId == collaborator.id ? 'selected' : '' }}>{{ collaborator.name }}</option>
                        {% endfor %}
                    </select>
                    <div class="flex gap-2 md:col-span-3">
                        <button class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-md btn-mobile">
                            {{ 'actions.search'|trans }}
                        </button>
                        {% if q or status or collaboratorId %}
                            <a href="{{ path('app_prestation_index') }}"
                               class="px-4 py-2 bg-[#223044] hover:bg-[#2E415B] text-white font-semibold rounded-md btn-mobile">
                                {{ 'actions.reset'|trans }}
                            </a>
                        {% endif %}
                    </div>
                </form>
            </div>

            {% if pagination.items is not empty %}
                <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white shadow-lg">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'prestation.label'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'prestation.collaborator'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'prestation.sales_document'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'prestation.performed_at'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'prestation.amount'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'prestation.status'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'table.actions'|trans }}</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                        {% for prestation in pagination.items %}
                            {% set currency = prestation.salesDocument ? prestation.salesDocument.getResolvedCurrency() : 'EUR' %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4 text-sm font-semibold text-gray-900">{{ prestation.label }}</td>
                                <td class="px-6 py-4 text-sm text-gray-700">{{ prestation.collaborator.name }}</td>
                                <td class="px-6 py-4 text-sm text-gray-700">
                                    {% if prestation.salesDocument %}
                                        <a href="{{ path('app_sales_document_show', {'id': prestation.salesDocument.id}) }}" class="text-blue-600 hover:text-blue-500">
                                            {{ prestation.salesDocument.reference }}
                                        </a>
                                    {% else %}
                                        {{ 'common.dash'|trans }}
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-700">{{ prestation.performedAt|date('d/m/Y') }}</td>
                                <td class="px-6 py-4 text-sm text-gray-700">
                                    {{ prestation.total|format_currency(currency, app.request.locale ?: 'fr_FR') }}
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">
                                        {{ ('prestation.status_' ~ prestation.status)|trans }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <div class="flex flex-wrap gap-2">
                                        <a href="{{ path('app_prestation_show', {'id': prestation.id}) }}"
                                           class="px-3 py-1.5 rounded-md bg-[#223044] text-white text-xs font-semibold hover:bg-[#2E415B] transition">
                                            {{ 'actions.view'|trans }}
                                        </a>
                                        <a href="{{ path('app_prestation_edit', {'id': prestation.id}) }}"
                                           class="px-3 py-1.5 rounded-md bg-blue-600 text-white text-xs font-semibold hover:bg-blue-700 transition">
                                            {{ 'actions.edit'|trans }}
                                        </a>
                                        {{ include('prestation/_delete_form.html.twig', {prestation: prestation}) }}
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="px-6 py-10 text-center text-gray-400">{{ 'prestation.none'|trans }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>

                <div class="flex flex-wrap items-center justify-between gap-4">
                    <p class="text-sm text-gray-400">
                        {{ 'prestation.pagination'|trans({'count': pagination.items|length, 'total': pagination.total}) }}
                    </p>
                    <div class="flex flex-wrap gap-2">
                        {% for i in 1..pagination.pages %}
                            <a href="?page={{ i }}{% if q %}&q={{ q|url_encode }}{% endif %}{% if status %}&status={{ status|url_encode }}{% endif %}{% if collaboratorId %}&collaborator={{ collaboratorId }}{% endif %}"
                               class="px-3 py-1.5 rounded-lg text-sm font-medium {{ i == pagination.page ? 'bg-blue-600 text-white' : 'bg-[#223044] text-gray-200 hover:bg-[#2E415B]' }}">
                                {{ i }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% else %}
                <div class="rounded-2xl border border-dashed border-[#2A3747] bg-[#111922] p-10 text-center">
                    <p class="text-gray-400 mb-4">{{ 'prestation.none'|trans }}</p>
                    <a href="{{ path('app_prestation_new') }}"
                       class="inline-flex items-center justify-center px-5 py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold rounded-lg transition-colors btn-mobile">
                        {{ 'prestation.create_first'|trans }}
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
