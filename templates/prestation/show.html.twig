{% extends 'base.html.twig' %}

{% block title %}{{ 'prestation.details_title'|trans }}{% endblock %}

{% block body %}
    {% set currency = prestation.salesDocument ? prestation.salesDocument.getResolvedCurrency() : 'EUR' %}
    <div class="w-full px-6 py-8">
        <div class="space-y-6">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <h1 class="text-3xl sm:text-4xl font-bold text-white">{{ 'prestation.details_title'|trans }}</h1>
                    <p class="text-sm text-gray-400 mt-2">{{ prestation.label }}</p>
                </div>
                <div class="flex flex-col sm:flex-row flex-wrap gap-2 w-full sm:w-auto">
                    <a href="{{ path('app_prestation_index') }}"
                       class="px-4 py-2 bg-[#223044] rounded hover:bg-[#2E415B] text-white btn-mobile">← {{ 'actions.back'|trans }}</a>
                    <a href="{{ path('app_prestation_edit', {'id': prestation.id}) }}"
                       class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 font-semibold btn-mobile">{{ 'actions.edit'|trans }}</a>
                    {{ include('prestation/_delete_form.html.twig', {prestation: prestation}) }}
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-white p-6 rounded-2xl shadow-md">
                    <h2 class="text-gray-500 font-semibold mb-2">{{ 'prestation.collaborator'|trans }}</h2>
                    <p class="text-gray-900">{{ prestation.collaborator.name }}</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-md">
                    <h2 class="text-gray-500 font-semibold mb-2">{{ 'prestation.sales_document'|trans }}</h2>
                    {% if prestation.salesDocument %}
                        <a class="text-blue-600 hover:text-blue-500" href="{{ path('app_sales_document_show', {'id': prestation.salesDocument.id}) }}">
                            {{ prestation.salesDocument.reference }}
                        </a>
                    {% else %}
                        <p class="text-gray-900">{{ 'common.dash'|trans }}</p>
                    {% endif %}
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-md">
                    <h2 class="text-gray-500 font-semibold mb-2">{{ 'prestation.performed_at'|trans }}</h2>
                    <p class="text-gray-900">{{ prestation.performedAt|date('d/m/Y') }}</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-md">
                    <h2 class="text-gray-500 font-semibold mb-2">{{ 'prestation.quantity'|trans }}</h2>
                    <p class="text-gray-900">{{ prestation.quantity ?: 'common.dash'|trans }}</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-md">
                    <h2 class="text-gray-500 font-semibold mb-2">{{ 'prestation.unit_price'|trans }}</h2>
                    <p class="text-gray-900">
                        {{ prestation.unitPrice ? prestation.unitPrice|format_currency(currency, app.request.locale ?: 'fr_FR') : 'common.dash'|trans }}
                    </p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-md">
                    <h2 class="text-gray-500 font-semibold mb-2">{{ 'prestation.amount'|trans }}</h2>
                    <p class="text-gray-900">{{ prestation.total|format_currency(currency, app.request.locale ?: 'fr_FR') }}</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-md">
                    <h2 class="text-gray-500 font-semibold mb-2">{{ 'prestation.status'|trans }}</h2>
                    <p class="text-gray-900">{{ ('prestation.status_' ~ prestation.status)|trans }}</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-md md:col-span-2">
                    <h2 class="text-gray-500 font-semibold mb-2">{{ 'prestation.notes'|trans }}</h2>
                    <p class="text-gray-900">{{ prestation.notes ?: 'common.dash'|trans }}</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
