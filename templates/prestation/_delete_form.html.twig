{% if canDelete|default(prestation.status == 'draft') %}
<form method="post" action="{{ path('app_prestation_delete', {'id': prestation.id}) }}" onsubmit="return confirm('{{ 'prestation.delete_confirm'|trans }}');" class="w-full">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ prestation.id) }}">
    <button class="w-full px-3 py-2 rounded bg-red-600 text-white text-xs font-semibold hover:bg-red-700 transition">
        {{ 'actions.delete'|trans }}
    </button>
</form>
{% else %}
    <button type="button"
            disabled
            title="{{ 'prestation.delete_locked_help'|trans }}"
            class="w-full cursor-not-allowed px-3 py-2 rounded bg-gray-200 text-gray-500 text-xs font-semibold">
        {{ 'actions.delete'|trans }}
    </button>
{% endif %}
