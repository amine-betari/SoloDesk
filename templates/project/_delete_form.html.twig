{% set canDelete = canDelete is defined ? canDelete : project.canBeDeleted %}
{% if canDelete %}
    <form method="post" action="{{ path('app_project_delete', {'id': project.id}) }}" onsubmit="return confirm('{{ 'common.delete_confirm'|trans }}');" class="w-full sm:w-auto">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ project.id) }}">
        <button class="w-full px-4 py-2 bg-red-500 text-white rounded transition hover:bg-red-600 btn-mobile">{{ 'actions.delete'|trans }}</button>
    </form>
{% else %}
    <p class="px-3 py-2 rounded bg-amber-50 text-amber-800 text-xs font-semibold">{{ 'project.delete_linked_help'|trans }}</p>
{% endif %}
