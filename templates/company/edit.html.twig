{% extends 'base.html.twig' %}

{% block title %}Mon entreprise{% endblock %}

{% block body %}
    <div class="mt-12 p-8 bg-white text-gray-900 rounded-xl">
        <h1 class="text-4xl font-extrabold mb-8">Mon entreprise</h1>

        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

        <fieldset class="bg-gray-50 p-6 rounded-lg space-y-6">
            <legend class="text-lg font-semibold text-gray-900">Informations générales</legend>

            <div class="space-y-2">
                {{ form_label(form.name, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-900'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-white text-gray-900'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4" data-controller="company-legal-form">
                <div class="space-y-2">
                    {{ form_label(form.legalForm, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-900'}}) }}
                    {{ form_widget(form.legalForm, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-white text-gray-900', 'data-company-legal-form-target': 'legalForm', 'data-action': 'change->company-legal-form#toggle'}}) }}
                    {{ form_errors(form.legalForm) }}
                </div>
                <div class="space-y-2 hidden" data-company-legal-form-target="rcField">
                    {{ form_label(form.rcNumber, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-900'}}) }}
                    {{ form_widget(form.rcNumber, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-white text-gray-900'}}) }}
                    {{ form_errors(form.rcNumber) }}
                </div>
                <div class="space-y-2">
                    {{ form_label(form.ice, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-900'}}) }}
                    {{ form_widget(form.ice, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-white text-gray-900'}}) }}
                    {{ form_errors(form.ice) }}
                </div>
                <div class="space-y-2">
                    {{ form_label(form.fiscalId, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-900'}}) }}
                    {{ form_widget(form.fiscalId, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-white text-gray-900'}}) }}
                    {{ form_errors(form.fiscalId) }}
                </div>
                <div class="space-y-2">
                    {{ form_label(form.taxProfessional, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-900'}}) }}
                    {{ form_widget(form.taxProfessional, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-white text-gray-900'}}) }}
                    {{ form_errors(form.taxProfessional) }}
                </div>
                <div class="space-y-2">
                    {{ form_label(form.phone, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-900'}}) }}
                    {{ form_widget(form.phone, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-white text-gray-900'}}) }}
                    {{ form_errors(form.phone) }}
                </div>
                <div class="space-y-2">
                    {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-900'}}) }}
                    {{ form_widget(form.email, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-white text-gray-900'}}) }}
                    {{ form_errors(form.email) }}
                </div>
                <div class="space-y-2">
                    {{ form_label(form.city, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-900'}}) }}
                    {{ form_widget(form.city, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-white text-gray-900'}}) }}
                    {{ form_errors(form.city) }}
                </div>
                <div class="space-y-2">
                    {{ form_label(form.country, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-900'}}) }}
                    {{ form_widget(form.country, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-white text-gray-900'}}) }}
                    {{ form_errors(form.country) }}
                </div>
            </div>

            <div class="space-y-2">
                {{ form_label(form.address, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-900'}}) }}
                <div
                    class="company-ckeditor"
                    data-controller="ckeditor"
                    data-ckeditor-toolbar-value='["bold","italic","bulletedList","numberedList","undo","redo"]'
                    data-ckeditor-license-key-value="GPL"
                >
                    {{ form_widget(form.address, {
                        attr: { 'data-ckeditor-target':'textarea', rows:6, class:'mt-1 w-full rounded-md border-gray-300 bg-white text-gray-900' }
                    }) }}
                </div>
                {{ form_errors(form.address) }}
            </div>

            <div class="space-y-2"
                 data-controller="logo-dropzone"
                 data-logo-dropzone-current-src-value="{{ app.user and app.user.company and app.user.company.logoPath ? '/' ~ app.user.company.logoPath : '' }}">
                {{ form_label(form.logoFile, 'Logo', {'label_attr': {'class': 'block text-sm font-medium text-gray-900'}}) }}

                <div class="mt-2 rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 p-4 text-center transition"
                     data-logo-dropzone-target="dropzone">
                    <div class="text-sm text-gray-600">
                        Glissez-déposez votre logo ici, ou
                        <button type="button"
                                class="text-blue-600 hover:text-blue-700 font-semibold"
                                data-action="logo-dropzone#open">
                            choisir un fichier
                        </button>
                    </div>
                    <div class="mt-3 text-xs text-gray-500">Formats: png, jpg, svg, webp</div>

                    {{ form_widget(form.logoFile, {
                        'attr': {
                            'class': 'hidden',
                            'data-logo-dropzone-target': 'input',
                            'data-action': 'change->logo-dropzone#preview'
                        }
                    }) }}

                    <div class="mt-4 flex items-center justify-center gap-4">
                        <img data-logo-dropzone-target="preview"
                             class="hidden h-20 rounded-md border border-gray-200 bg-white p-1"
                             alt="Logo preview">
                        <span data-logo-dropzone-target="filename" class="text-xs text-gray-500"></span>
                    </div>
                </div>

                {{ form_errors(form.logoFile) }}
            </div>

            <style>
                .company-ckeditor .ck-content { color: #111827; }
            </style>

            <div class="flex justify-end items-center">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded btn-mobile">
                    Enregistrer
                </button>
            </div>
        </fieldset>

        {{ form_end(form) }}
    </div>
{% endblock %}
