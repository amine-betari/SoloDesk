{% if app.request.query.getBoolean('created') %}
    <div class="rounded-xl border border-emerald-300 bg-emerald-50 p-4 text-emerald-950 shadow-sm">
        <div class="font-bold">{{ 'form.created_success'|trans }}</div>
        <div class="mt-3 flex flex-col gap-2 sm:flex-row sm:flex-wrap">
            {% for action in creation_actions %}
                <a href="{{ action.url }}"
                   class="inline-flex items-center justify-center rounded-lg px-4 py-2 text-sm font-semibold {{ action.primary|default(false) ? 'bg-emerald-600 text-white hover:bg-emerald-700' : 'bg-white text-emerald-800 hover:bg-emerald-100' }}">
                    {{ action.label|trans }}
                </a>
            {% endfor %}
        </div>
    </div>
{% endif %}
