<aside data-new-form-target="financialSummary" class="rounded-xl border border-blue-100 bg-blue-50 p-5">
    <div class="flex flex-wrap items-center justify-between gap-2">
        <h3 class="text-sm font-bold uppercase tracking-wide text-blue-900">{{ 'form.financial_summary'|trans }}</h3>
        <span class="text-xs font-semibold text-blue-700">
            {{ 'form.currency'|trans }} :
            <span data-new-form-target="currency">—</span>
        </span>
    </div>
    <dl class="mt-4 grid grid-cols-1 gap-3 text-sm sm:grid-cols-3">
        <div>
            <dt class="text-blue-700">{{ 'form.total_ht'|trans }}</dt>
            <dd data-new-form-target="totalHt" class="mt-1 text-lg font-bold text-blue-950">0,00</dd>
        </div>
        <div>
            <dt class="text-blue-700">{{ 'form.vat_amount'|trans }}</dt>
            <dd data-new-form-target="vatAmount" class="mt-1 text-lg font-bold text-blue-950">0,00</dd>
        </div>
        <div>
            <dt class="text-blue-700">{{ 'form.total_ttc'|trans }}</dt>
            <dd data-new-form-target="totalTtc" class="mt-1 text-lg font-bold text-blue-950">0,00</dd>
        </div>
    </dl>
</aside>
