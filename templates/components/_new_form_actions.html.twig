<div class="sticky bottom-4 z-20 mt-8 flex flex-col-reverse gap-3 rounded-xl border border-gray-200 bg-white/95 p-4 shadow-lg backdrop-blur sm:flex-row sm:justify-end">
    <a href="{{ path(cancel_route) }}"
       class="inline-flex items-center justify-center rounded-lg bg-gray-100 px-6 py-3 font-semibold text-gray-800 hover:bg-gray-200 btn-mobile">
        {{ 'actions.cancel'|trans }}
    </a>
    <button type="submit"
            form="{{ form_id }}"
            class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-6 py-3 font-bold text-white hover:bg-blue-700 btn-mobile">
        {{ 'actions.save'|trans }}
    </button>
</div>
