{% extends 'base.html.twig' %}

{% block title %}Détails du collaborateur{% endblock %}

{% block body %}
    <div class="w-full px-6 py-8">
        <div class="bg-white text-gray-900 rounded-2xl shadow-xl p-8">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-3xl sm:text-4xl font-bold">Collaborateur : {{ collaborator.name }}</h1>
                    <p class="text-sm text-gray-500 mt-2">{{ collaborator.role ?: 'Rôle non renseigné' }}</p>
                </div>
                <div class="flex items-center gap-2">
                    {% set typeLabel = collaborator.type ?: '—' %}
                    {% set typeClass = 'bg-gray-100 text-gray-700' %}
                    {% if collaborator.type == 'salarie' %}
                        {% set typeLabel = 'Salarié' %}
                        {% set typeClass = 'bg-emerald-100 text-emerald-700' %}
                    {% elseif collaborator.type == 'freelance' %}
                        {% set typeLabel = 'Freelance' %}
                        {% set typeClass = 'bg-blue-100 text-blue-700' %}
                    {% elseif collaborator.type == 'collaborateur' %}
                        {% set typeLabel = 'Collaborateur' %}
                        {% set typeClass = 'bg-amber-100 text-amber-700' %}
                    {% endif %}
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold {{ typeClass }}">
                        {{ typeLabel }}
                    </span>
                </div>
                <div class="flex gap-2">
                    <a href="{{ path('app_collaborator_edit', {'id': collaborator.id}) }}"
                       class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded font-semibold btn-mobile">
                        Modifier
                    </a>
                    {{ include('collaborator/_delete_form.html.twig') }}
                </div>
            </div>

            <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-200">
                    <div class="text-xs uppercase tracking-wider text-gray-500">Type</div>
                    <div class="mt-2 text-lg font-semibold text-gray-900">{{ collaborator.type ?: '—' }}</div>
                </div>
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-200">
                    <div class="text-xs uppercase tracking-wider text-gray-500">Coût mensuel</div>
                    <div class="mt-2 text-lg font-semibold text-gray-900">
                        {{ collaborator.monthlyCost is not null ? collaborator.monthlyCost|number_format(2, '.', ' ') : '—' }}
                    </div>
                </div>
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-200 md:col-span-2">
                    <div class="text-xs uppercase tracking-wider text-gray-500">Compétences</div>
                    <div class="mt-2 text-gray-800">
                        {% if collaborator.skills is not empty %}
                            {{ collaborator.skills|map(s => s.name)|join(', ') }}
                        {% else %}
                            —
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="mt-8">
                <h2 class="text-xl font-bold text-gray-900 mb-4">Notes</h2>
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-200 text-gray-800">
                    {{ collaborator.notes ? collaborator.notes|sanitize_html : 'Aucune note disponible.' }}
                </div>
            </div>

            <div class="mt-6">
                <a href="{{ path('app_collaborator_index') }}"
                   class="px-4 py-2 bg-[#223044] hover:bg-[#2E415B] rounded text-white btn-mobile">← Retour à la liste</a>
            </div>
        </div>
    </div>
{% endblock %}
