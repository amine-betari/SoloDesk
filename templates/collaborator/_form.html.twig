<div class="w-full px-6 py-8">
    <div class="bg-white text-gray-900 rounded-2xl shadow-xl p-8">

        {% if button_label is defined  %}
            <h1 class="text-3xl font-bold mb-6">{{ 'collaborator.edit_title'|trans }}</h1>
        {% else %}
            <h1 class="text-3xl font-bold mb-6">{{ 'collaborator.new_title'|trans }}</h1>
        {% endif %}

        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

        <fieldset class="space-y-4 p-6 bg-white rounded-lg shadow-inner border border-gray-200" data-controller="collaborator-type-badge">
            <legend class="text-xl font-semibold mb-4 text-gray-900">{{ 'common.information'|trans }}</legend>

            <div>
                {{ form_label(form.name, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-gray-50 text-gray-900 placeholder-gray-400'}}) }}
                {{ form_errors(form.name, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.role, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.role, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-gray-50 text-gray-900 placeholder-gray-400'}}) }}
                    {{ form_errors(form.role, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
                </div>

                <div>
                    {{ form_label(form.type, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.type, {'attr': {
                        'class': 'mt-1 w-full rounded-md border-gray-300 bg-gray-50 text-gray-900 placeholder-gray-400',
                        'data-collaborator-type-badge-target': 'select',
                        'data-action': 'change->collaborator-type-badge#update'
                    }}) }}
                    {{ form_errors(form.type, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
                    <div class="mt-2">
                        <span data-collaborator-type-badge-target="badge"
                              class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">
                            —
                        </span>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.monthlyCost, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.monthlyCost, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-gray-50 text-gray-900 placeholder-gray-400'}}) }}
                    {{ form_errors(form.monthlyCost, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
                </div>

                <div>
                    {{ form_label(form.skills, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.skills) }}
                    {{ form_errors(form.skills, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
                    <p class="text-xs text-gray-500 mt-1">{{ 'collaborator.skills_help'|trans }}</p>
                </div>
            </div>

            <div>
                {{ form_label(form.notes, 'collaborator.notes'|trans, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                <div
                    data-controller="ckeditor"
                    data-ckeditor-toolbar-value='["bold","italic","bulletedList","numberedList","undo","redo"]'
                    data-ckeditor-license-key-value="GPL"
                >
                    {{ form_widget(form.notes, {
                        attr: { 'data-ckeditor-target':'textarea', rows:10, class:'mt-1 w-full rounded-md border-gray-300 bg-white' }
                    }) }}
                </div>
                {{ form_errors(form.notes, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
            </div>
        </fieldset>

        <div class="flex justify-end mt-6">
            <button class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg shadow-md btn-mobile">
                {{ 'actions.save'|trans }}
            </button>
        </div>

        {{ form_end(form) }}

        {% if button_label is defined  %}
            <div class="flex flex-col sm:flex-row gap-3 mt-4">
                <a href="{{ path('app_collaborator_index') }}"
                   class="px-4 py-2 bg-[#223044] hover:bg-[#2E415B] rounded text-white btn-mobile">← {{ 'actions.back_to_list'|trans }}</a>

                {{ include('collaborator/_delete_form.html.twig') }}
            </div>
        {% else %}
            <a href="{{ path('app_collaborator_index') }}"
               class="px-4 py-2 bg-[#223044] hover:bg-[#2E415B] rounded text-white mt-4 inline-block">← {{ 'actions.back_to_list'|trans }}</a>
        {% endif %}
    </div>
</div>
