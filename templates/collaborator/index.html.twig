{% extends 'base.html.twig' %}

{% block title %}Liste des collaborateurs{% endblock %}

{% block body %}
    <div class="w-full px-6 py-8">
        <div class="space-y-6">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <h1 class="text-3xl sm:text-4xl font-bold text-white">Collaborateurs</h1>
                    <p class="text-sm text-gray-400 mt-2">Gérez vos collaborateurs, salariés ou freelances.</p>
                </div>
                <div class="flex items-center gap-3">
                    <div class="hidden sm:flex items-center gap-2 rounded-full bg-[#1F2732] border border-[#2A3747] px-4 py-2 text-sm text-gray-300">
                        <span class="text-gray-500">Total</span>
                        <span class="text-white font-semibold">{{ pagination.total }}</span>
                    </div>
                    <a href="{{ path('app_collaborator_new') }}"
                       class="inline-flex items-center justify-center px-5 py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold rounded-lg transition-colors btn-mobile">
                        Nouveau collaborateur
                    </a>
                </div>
            </div>

            <div class="bg-[#1F2732] border border-[#2A3747] rounded-2xl p-4">
                <form method="get" class="flex flex-col md:flex-row gap-3 md:items-center">
                    <input
                        type="text"
                        name="q"
                        value="{{ q }}"
                        placeholder="Rechercher par compétence, nom ou rôle..."
                        class="w-full md:flex-1 rounded-md border border-[#2A3747] bg-[#111922] text-gray-100 placeholder-gray-500 px-4 py-2"
                    />
                    <div class="flex gap-2">
                        <button class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-md btn-mobile">
                            Rechercher
                        </button>
                        {% if q %}
                            <a href="{{ path('app_collaborator_index') }}"
                               class="px-4 py-2 bg-[#223044] hover:bg-[#2E415B] text-white font-semibold rounded-md btn-mobile">
                                Réinitialiser
                            </a>
                        {% endif %}
                    </div>
                </form>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="rounded-2xl border border-[#2A3747] bg-[#1F2732] p-4">
                    <div class="text-xs uppercase tracking-wider text-gray-400">Collaborateurs affichés</div>
                    <div class="mt-2 text-2xl font-semibold text-white">{{ pagination.items|length }}</div>
                </div>
                <div class="rounded-2xl border border-[#2A3747] bg-[#1F2732] p-4">
                    <div class="text-xs uppercase tracking-wider text-gray-400">Collaborateurs au total</div>
                    <div class="mt-2 text-2xl font-semibold text-white">{{ pagination.total }}</div>
                </div>
                <div class="rounded-2xl border border-[#2A3747] bg-[#1F2732] p-4">
                    <div class="text-xs uppercase tracking-wider text-gray-400">Page</div>
                    <div class="mt-2 text-2xl font-semibold text-white">{{ pagination.page }} / {{ pagination.pages }}</div>
                </div>
            </div>

            {% if pagination.items is not empty %}
                <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white shadow-lg">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Collaborateur</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 hidden md:table-cell">Type</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 hidden lg:table-cell">Compétences</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Actions</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                        {% for collaborator in pagination.items %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-gray-100 text-gray-800 flex items-center justify-center font-semibold">
                                            {{ collaborator.name ? collaborator.name|slice(0, 1)|upper : '?' }}
                                        </div>
                                        <div class="min-w-0">
                                            <a href="{{ path('app_collaborator_show', {'id': collaborator.id}) }}"
                                               class="text-sm font-semibold text-gray-900 hover:text-blue-600 transition-colors">
                                                {{ collaborator.name }}
                                            </a>
                                            <div class="text-xs text-gray-500 truncate max-w-[260px]">{{ collaborator.role ?: 'Rôle non renseigné' }}</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm hidden md:table-cell">
                                    {% set typeLabel = collaborator.type ?: '—' %}
                                    {% set typeClass = 'bg-gray-100 text-gray-700' %}
                                    {% if collaborator.type == 'salarie' %}
                                        {% set typeLabel = 'Salarié' %}
                                        {% set typeClass = 'bg-emerald-100 text-emerald-700' %}
                                    {% elseif collaborator.type == 'freelance' %}
                                        {% set typeLabel = 'Freelance' %}
                                        {% set typeClass = 'bg-blue-100 text-blue-700' %}
                                    {% elseif collaborator.type == 'collaborateur' %}
                                        {% set typeLabel = 'Collaborateur' %}
                                        {% set typeClass = 'bg-amber-100 text-amber-700' %}
                                    {% endif %}
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold {{ typeClass }}">
                                        {{ typeLabel }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600 hidden lg:table-cell">
                                    {% if collaborator.skills is not empty %}
                                        {{ collaborator.skills|map(s => s.name)|join(', ') }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <div class="hidden sm:flex flex-wrap gap-2">
                                        <a href="{{ path('app_collaborator_show', {'id': collaborator.id}) }}"
                                           class="px-3 py-1.5 rounded-md bg-gray-100 text-gray-700 text-xs font-semibold hover:bg-gray-200 transition">
                                            Voir
                                        </a>
                                        <a href="{{ path('app_collaborator_edit', {'id': collaborator.id}) }}"
                                           class="px-3 py-1.5 rounded-md bg-blue-600 text-white text-xs font-semibold hover:bg-blue-700 transition">
                                            Modifier
                                        </a>
                                    </div>
                                    <div class="sm:hidden">
                                        <details class="relative">
                                            <summary class="inline-flex items-center gap-2 px-3 py-1.5 text-xs font-semibold rounded bg-gray-100 text-gray-700">
                                                Actions
                                            </summary>
                                            <div class="mt-2 flex flex-col gap-2">
                                                <a href="{{ path('app_collaborator_show', {'id': collaborator.id}) }}"
                                                   class="px-3 py-2 rounded bg-gray-100 text-gray-700 text-xs font-semibold hover:bg-gray-200">Voir</a>
                                                <a href="{{ path('app_collaborator_edit', {'id': collaborator.id}) }}"
                                                   class="px-3 py-2 rounded bg-blue-600 text-white text-xs font-semibold hover:bg-blue-700">Modifier</a>
                                            </div>
                                        </details>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="px-6 py-10 text-center text-gray-400">Aucun collaborateur trouvé</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>

                <div class="flex flex-wrap items-center justify-between gap-4">
                    <p class="text-sm text-gray-400">
                        Affichage de {{ pagination.items|length }} sur {{ pagination.total }} collaborateurs
                    </p>
                    <div class="flex flex-wrap gap-2">
                        {% for i in 1..pagination.pages %}
                            <a href="?page={{ i }}{% if q %}&q={{ q|url_encode }}{% endif %}"
                               class="px-3 py-1.5 rounded-lg text-sm font-medium {{ i == pagination.page ? 'bg-blue-600 text-white' : 'bg-[#223044] text-gray-200 hover:bg-[#2E415B]' }}">
                                {{ i }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% else %}
                <div class="rounded-2xl border border-dashed border-[#2A3747] bg-[#111922] p-10 text-center">
                    <p class="text-gray-400 mb-4">Aucun collaborateur trouvé.</p>
                    <a href="{{ path('app_collaborator_new') }}"
                       class="inline-flex items-center justify-center px-5 py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold rounded-lg transition-colors btn-mobile">
                        Créer votre premier collaborateur
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
