{% extends 'base.html.twig' %}

{% block title %}{{ 'collaborator.list_title'|trans }}{% endblock %}

{% block body %}
    <div class="w-full px-6 py-8">
        <div class="space-y-6">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <h1 class="text-3xl sm:text-4xl font-bold text-white">{{ 'collaborator.title'|trans }}</h1>
                    <p class="text-sm text-gray-400 mt-2">{{ 'collaborator.subtitle'|trans }}</p>
                </div>
                <div class="flex items-center gap-3">
                    <a href="{{ path('app_collaborator_new') }}"
                       class="inline-flex items-center justify-center px-5 py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold rounded-lg transition-colors btn-mobile">
                        {{ 'collaborator.new'|trans }}
                    </a>
                </div>
            </div>

            <div class="bg-[#1F2732] border border-[#2A3747] rounded-2xl p-4">
                <form method="get" class="flex flex-col gap-3">
                    <div class="flex flex-col md:flex-row gap-3 md:items-center">
                    <input
                        type="text"
                        name="q"
                        value="{{ q }}"
                        placeholder="{{ 'collaborator.search_placeholder'|trans }}"
                        list="skill-suggestions"
                        class="w-full md:flex-1 rounded-md border border-[#2A3747] bg-[#111922] text-gray-100 placeholder-gray-500 px-4 py-2"
                    />
                    <div class="flex gap-2">
                        <button class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-md btn-mobile">
                            {{ 'actions.search'|trans }}
                        </button>
                        {% if q or type or skillId or sort != 'name_asc' %}
                            <a href="{{ path('app_collaborator_index') }}"
                               class="px-4 py-2 bg-[#223044] hover:bg-[#2E415B] text-white font-semibold rounded-md btn-mobile">
                                {{ 'actions.reset'|trans }}
                            </a>
                        {% endif %}
                    </div>
                    </div>
                    <datalist id="skill-suggestions">
                        {% for skill in skills %}
                            <option value="{{ skill.name }}"></option>
                        {% endfor %}
                    </datalist>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                        <div>
                            <label class="text-xs uppercase tracking-wider text-gray-400">{{ 'collaborator.filter_type'|trans }}</label>
                            <select name="type"
                                    class="mt-1 w-full rounded-md border border-[#2A3747] bg-[#111922] text-gray-100 px-3 py-2">
                                <option value="">{{ 'common.all'|trans }}</option>
                                <option value="salarie" {{ type == 'salarie' ? 'selected' : '' }}>{{ 'collaborator.type_salarie'|trans }}</option>
                                <option value="freelance" {{ type == 'freelance' ? 'selected' : '' }}>{{ 'collaborator.type_freelance'|trans }}</option>
                                <option value="collaborateur" {{ type == 'collaborateur' ? 'selected' : '' }}>{{ 'collaborator.type_collaborateur'|trans }}</option>
                            </select>
                        </div>
                        <div>
                            <label class="text-xs uppercase tracking-wider text-gray-400">{{ 'collaborator.filter_skill'|trans }}</label>
                            <select name="skill"
                                    class="mt-1 w-full rounded-md border border-[#2A3747] bg-[#111922] text-gray-100 px-3 py-2">
                                <option value="">{{ 'common.all_f'|trans }}</option>
                                {% for skill in skills %}
                                    <option value="{{ skill.id }}" {{ skillId == skill.id ? 'selected' : '' }}>
                                        {{ skill.name }}{% if skill.isCore %} ★{% endif %}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div>
                            <label class="text-xs uppercase tracking-wider text-gray-400">{{ 'common.sort'|trans }}</label>
                            <select name="sort"
                                    class="mt-1 w-full rounded-md border border-[#2A3747] bg-[#111922] text-gray-100 px-3 py-2">
                                <option value="name_asc" {{ sort == 'name_asc' ? 'selected' : '' }}>{{ 'collaborator.sort_name_asc'|trans }}</option>
                                <option value="name_desc" {{ sort == 'name_desc' ? 'selected' : '' }}>{{ 'collaborator.sort_name_desc'|trans }}</option>
                                <option value="role_asc" {{ sort == 'role_asc' ? 'selected' : '' }}>{{ 'collaborator.sort_role_asc'|trans }}</option>
                                <option value="role_desc" {{ sort == 'role_desc' ? 'selected' : '' }}>{{ 'collaborator.sort_role_desc'|trans }}</option>
                                <option value="cost_asc" {{ sort == 'cost_asc' ? 'selected' : '' }}>{{ 'collaborator.sort_cost_asc'|trans }}</option>
                                <option value="cost_desc" {{ sort == 'cost_desc' ? 'selected' : '' }}>{{ 'collaborator.sort_cost_desc'|trans }}</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
                <div class="rounded-2xl border border-[#2A3747] bg-[#1F2732] p-5">
                    <div class="flex items-center justify-between gap-4">
                        <div>
                            <div class="text-xs uppercase tracking-wider text-gray-400">{{ 'collaborator.count_total'|trans }}</div>
                            <div class="mt-2 text-3xl font-semibold text-white">{{ pagination.total }}</div>
                        </div>
                        <div class="text-sm text-gray-400">{{ 'common.page'|trans }} {{ pagination.page }} / {{ pagination.pages }}</div>
                    </div>
                    <div class="mt-5 grid grid-cols-3 gap-3 border-t border-[#2A3747] pt-4">
                        <div>
                            <div class="text-xs text-gray-400">{{ 'collaborator.type_salarie'|trans }}</div>
                            <div class="mt-1 text-xl font-semibold text-white">{{ countsByType.salarie }}</div>
                        </div>
                        <div>
                            <div class="text-xs text-gray-400">{{ 'collaborator.type_freelance'|trans }}</div>
                            <div class="mt-1 text-xl font-semibold text-white">{{ countsByType.freelance }}</div>
                        </div>
                        <div>
                            <div class="text-xs text-gray-400">{{ 'collaborator.type_collaborateur'|trans }}</div>
                            <div class="mt-1 text-xl font-semibold text-white">{{ countsByType.collaborateur }}</div>
                        </div>
                    </div>
                </div>

                <div class="rounded-2xl border border-[#2A3747] bg-[#1F2732] p-5">
                    <div class="text-xs uppercase tracking-wider text-gray-400">{{ 'collaborator.top_skills'|trans }}</div>
                    <div class="mt-3 flex flex-wrap gap-2">
                        {% if topSkills is not empty %}
                            {% for s in topSkills %}
                                <a href="{{ path('app_collaborator_index', {
                                    skill: skillId == s.id ? null : s.id,
                                    type: type ?: null,
                                    sort: sort != 'name_asc' ? sort : null
                                }) }}"
                                   class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold transition-colors {{ skillId == s.id ? 'bg-blue-600 text-white' : 'bg-[#223044] text-gray-200 hover:bg-[#2E415B]' }}">
                                    {{ s.name }} ({{ s.total }})
                                </a>
                            {% endfor %}
                        {% else %}
                            <span class="text-sm text-gray-400">{{ 'collaborator.no_skills'|trans }}</span>
                        {% endif %}
                    </div>
                    <p class="mt-3 text-xs text-gray-500">{{ 'collaborator.top_skills_help'|trans }}</p>
                </div>
            </div>

            {% if pagination.items is not empty %}
                <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white shadow-lg">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'collaborator.table_name'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 hidden md:table-cell">{{ 'collaborator.table_type'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 hidden lg:table-cell">{{ 'collaborator.table_skills'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 hidden lg:table-cell">{{ 'collaborator.monthly_cost'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'table.actions'|trans }}</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                        {% for collaborator in pagination.items %}
                            <tr class="hover:bg-gray-50 transition-colors cursor-pointer"
                                tabindex="0"
                                role="link"
                                onclick="if (!event.target.closest('a, button, summary, details')) window.location.href='{{ path('app_collaborator_show', {'id': collaborator.id}) }}'"
                                onkeydown="if ((event.key === 'Enter' || event.key === ' ') && !event.target.closest('a, button, summary, details')) { event.preventDefault(); window.location.href='{{ path('app_collaborator_show', {'id': collaborator.id}) }}'; }">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-gray-100 text-gray-800 flex items-center justify-center font-semibold">
                                            {{ collaborator.name ? collaborator.name|slice(0, 1)|upper : '?' }}
                                        </div>
                                        <div class="min-w-0">
                                            <a href="{{ path('app_collaborator_show', {'id': collaborator.id}) }}"
                                               class="text-sm font-semibold text-gray-900 hover:text-blue-600 transition-colors">
                                                {{ collaborator.name }}
                                            </a>
                                            <div class="text-xs text-gray-500 truncate max-w-[260px]">{{ collaborator.role ?: ('collaborator.role_empty'|trans) }}</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm hidden md:table-cell">
                                    {% set typeLabel = collaborator.type ?: ('common.dash'|trans) %}
                                    {% set typeClass = 'bg-gray-100 text-gray-700' %}
                                    {% if collaborator.type == 'salarie' %}
                                        {% set typeLabel = 'collaborator.type_salarie'|trans %}
                                        {% set typeClass = 'bg-emerald-100 text-emerald-700' %}
                                    {% elseif collaborator.type == 'freelance' %}
                                        {% set typeLabel = 'collaborator.type_freelance'|trans %}
                                        {% set typeClass = 'bg-blue-100 text-blue-700' %}
                                    {% elseif collaborator.type == 'collaborateur' %}
                                        {% set typeLabel = 'collaborator.type_collaborateur'|trans %}
                                        {% set typeClass = 'bg-amber-100 text-amber-700' %}
                                    {% endif %}
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold {{ typeClass }}">
                                        {{ typeLabel }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600 hidden lg:table-cell">
                                    {% if collaborator.skills is not empty %}
                                        <div class="flex flex-wrap gap-1">
                                            {% for skill in collaborator.skills %}
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold bg-indigo-50 text-indigo-700">
                                                    {{ skill.name }}
                                                </span>
                                            {% endfor %}
                                        </div>
                                    {% else %}
                                        {{ 'common.dash'|trans }}
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-700 hidden lg:table-cell">
                                    {{ collaborator.monthlyCost is not null ? collaborator.monthlyCost|number_format(2, ',', ' ') : ('common.dash'|trans) }}
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <details class="relative">
                                        <summary class="list-none inline-flex cursor-pointer items-center gap-2 px-3 py-1.5 text-xs font-semibold rounded bg-gray-100 text-gray-700 hover:bg-gray-200 transition">
                                            {{ 'table.actions'|trans }}
                                        </summary>
                                        <div class="absolute right-0 mt-2 z-10 w-48 rounded-lg border border-gray-200 bg-white shadow-lg p-2 flex flex-col gap-2">
                                            <a href="{{ path('app_prestation_new', {'collaborator': collaborator.id}) }}"
                                               class="px-3 py-2 rounded bg-emerald-600 text-white text-xs font-semibold hover:bg-emerald-700">{{ 'prestation.new'|trans }}</a>
                                            <a href="{{ path('app_collaborator_edit', {'id': collaborator.id}) }}"
                                               class="px-3 py-2 rounded bg-blue-600 text-white text-xs font-semibold hover:bg-blue-700">{{ 'actions.edit'|trans }}</a>
                                        </div>
                                    </details>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="px-6 py-10 text-center text-gray-400">{{ 'collaborator.none'|trans }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>

                <div class="flex flex-wrap items-center justify-between gap-4">
                    <p class="text-sm text-gray-400">
                        {{ 'collaborator.pagination'|trans({'%count%': pagination.items|length, '%total%': pagination.total}) }}
                    </p>
                    <div class="flex flex-wrap gap-2">
                        {% for i in 1..pagination.pages %}
                            <a href="?page={{ i }}{% if q %}&q={{ q|url_encode }}{% endif %}{% if type %}&type={{ type|url_encode }}{% endif %}{% if skillId %}&skill={{ skillId }}{% endif %}{% if sort %}&sort={{ sort|url_encode }}{% endif %}"
                               class="px-3 py-1.5 rounded-lg text-sm font-medium {{ i == pagination.page ? 'bg-blue-600 text-white' : 'bg-[#223044] text-gray-200 hover:bg-[#2E415B]' }}">
                                {{ i }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% else %}
                <div class="rounded-2xl border border-dashed border-[#2A3747] bg-[#111922] p-10 text-center">
                    <p class="text-gray-400 mb-4">{{ 'collaborator.none'|trans }}</p>
                    <a href="{{ path('app_collaborator_new') }}"
                       class="inline-flex items-center justify-center px-5 py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold rounded-lg transition-colors btn-mobile">
                        {{ 'collaborator.create_first'|trans }}
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
