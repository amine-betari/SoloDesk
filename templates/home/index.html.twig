{% extends 'base.html.twig' %}

{% block title %}{{ 'home.title'|trans }}{% endblock %}

{% block body %}

    <div class="bg-[#1F2732] border border-[#2A3747] rounded-xl p-6 mb-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h2 class="text-xl font-bold text-white">{{ 'home.quick_start'|trans }}</h2>
                <p class="text-sm text-gray-400 mt-1">{{ 'home.quick_start_subtitle'|trans }}</p>
            </div>
            <a href="{{ path('app_settings') }}" class="px-4 py-2 bg-blue-600 text-white rounded font-semibold text-sm hover:bg-blue-700 btn-mobile">
                {{ 'nav.settings'|trans }}
            </a>
        </div>
        <div class="mt-5 grid grid-cols-1 sm:grid-cols-3 gap-4">
            <a href="{{ path('app_company_edit') }}" class="group bg-[#16202A] border border-[#2A3747] rounded-lg p-4 hover:border-blue-500 transition">
                <div class="text-xs uppercase text-gray-500">{{ 'home.step_1'|trans }}</div>
                <div class="text-white font-semibold mt-1">{{ 'home.step_company_title'|trans }}</div>
                <div class="text-sm text-gray-400 mt-2">{{ 'home.step_company_desc'|trans }}</div>
            </a>
            <a href="{{ path('app_client_new') }}" class="group bg-[#16202A] border border-[#2A3747] rounded-lg p-4 hover:border-blue-500 transition">
                <div class="text-xs uppercase text-gray-500">{{ 'home.step_2'|trans }}</div>
                <div class="text-white font-semibold mt-1">{{ 'home.step_client_title'|trans }}</div>
                <div class="text-sm text-gray-400 mt-2">{{ 'home.step_client_desc'|trans }}</div>
            </a>
            <a href="{{ path('app_invoice_new') }}" class="group bg-[#16202A] border border-[#2A3747] rounded-lg p-4 hover:border-blue-500 transition">
                <div class="text-xs uppercase text-gray-500">{{ 'home.step_3'|trans }}</div>
                <div class="text-white font-semibold mt-1">{{ 'home.step_invoice_title'|trans }}</div>
                <div class="text-sm text-gray-400 mt-2">{{ 'home.step_invoice_desc'|trans }}</div>
            </a>
        </div>
    </div>

    {% include 'components/_overdue_invoices_list.html.twig' with {
        invoices: overdueInvoices,
        overdueDays: overdueDays,
        showProject: true
    } %}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">

        <!-- Clients -->
        <div class="bg-gray-50 p-6 rounded-lg shadow hover:shadow-lg transition-shadow">
            <h3 class="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-4">
                {{ 'home.card_clients'|trans }}
            </h3>
            {{ render_chart(clientDataChart) }}
        </div>

        <!-- Devis -->
        <div class="bg-gray-50 p-6 rounded-lg shadow hover:shadow-lg transition-shadow">
            <h3 class="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-4">
                {{ 'home.card_estimates'|trans }}
            </h3>
            {{ render_chart(estimateChart) }}
            <p class="text-sm text-gray-500 mt-2">{{ 'home.card_estimates_note'|trans }}</p>
        </div>

        <!-- Factures -->
        <div class="bg-gray-50 p-6 rounded-lg shadow hover:shadow-lg transition-shadow">
            <h3 class="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-4">
                {{ 'home.card_invoices'|trans }}
            </h3>
            {{ render_chart(invoiceChart) }}
            <p class="text-sm text-gray-500 mt-2">
                {{ 'home.card_invoices_note'|trans({'%count%': totalExternalInvoices}) }}
            </p>
        </div>

        <!-- CA par client -->
        <div class="bg-gray-50 p-6 rounded-lg shadow hover:shadow-lg transition-shadow">
            <h3 class="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-4">
                {{ 'home.card_revenue'|trans }}
            </h3>
            {{ render_chart(paymentsChart) }}
            <div class="mt-4">
                {% if hasPaymentsStats %}
                    <a href="{{ path('stats_ca_trimestre') }}"
                       class="text-blue-600 hover:underline text-sm font-medium btn-mobile inline-block">
                        {{ 'home.view_quarterly'|trans }}
                    </a>
                {% endif %}

            </div>
        </div>

    </div>

    <!-- Stat cards -->
    {% include 'partials/_stats.html.twig' with {
        projectCount: totalProjects,
        clientCount: totalClients,
        estimateCount: totalEstimates,
        invoiceCount: totalInvoices
    } %}

{% endblock %}
