{% extends 'base.html.twig' %}

{% block title %}{{ 'expense.details_title'|trans }}{% endblock %}

{% block body %}
    <div class="w-full px-6 py-8">
        <div class="space-y-6">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <h1 class="text-3xl sm:text-4xl font-bold text-white">{{ 'expense.details_title'|trans }}</h1>
                    <p class="text-sm text-gray-400 mt-2">{{ expense.label }}</p>
                </div>
                <div class="flex flex-col sm:flex-row flex-wrap gap-2 w-full sm:w-auto">
                    <a href="{{ path('app_expense_index') }}"
                       class="px-4 py-2 bg-[#223044] rounded hover:bg-[#2E415B] text-white btn-mobile">← {{ 'actions.back'|trans }}</a>
                    <a href="{{ path('app_expense_edit', {'id': expense.id}) }}"
                       class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 font-semibold btn-mobile">{{ 'actions.edit'|trans }}</a>
                    {{ include('expense/_delete_form.html.twig', {expense: expense}) }}
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                <div class="bg-white p-6 rounded-2xl shadow-md">
                    <h2 class="text-gray-500 font-semibold mb-2">{{ 'expense.amount'|trans }}</h2>
                    <p class="text-gray-900">{{ expense.amount|format_currency(expense.currency, app.request.locale ?: 'fr_FR') }}</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-md">
                    <h2 class="text-gray-500 font-semibold mb-2">{{ 'expense.category'|trans }}</h2>
                    <p class="text-gray-900">{{ ('expense.category_' ~ expense.category)|trans }}</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-md">
                    <h2 class="text-gray-500 font-semibold mb-2">{{ 'expense.spent_at'|trans }}</h2>
                    <p class="text-gray-900">{{ expense.spentAt|date('d/m/Y') }}</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-md">
                    <h2 class="text-gray-500 font-semibold mb-2">{{ 'expense.supplier'|trans }}</h2>
                    <p class="text-gray-900">{{ expense.supplier ?: 'common.dash'|trans }}</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-md md:col-span-2">
                    <h2 class="text-gray-500 font-semibold mb-2">{{ 'expense.notes'|trans }}</h2>
                    <p class="text-gray-900 whitespace-pre-line">{{ expense.notes ?: 'common.dash'|trans }}</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
