<div class="w-full px-6 py-8">
    <div class="bg-white text-gray-900 rounded-2xl shadow-xl p-8">
        <h1 class="text-3xl font-bold mb-6">
            {{ button_label is defined ? 'expense.edit_title'|trans : 'expense.new_title'|trans }}
        </h1>

        {{ form_start(form, {'attr': {'class': 'space-y-6', 'id': form.vars.id, 'data-controller': new_mode|default(false) ? 'new-form' : ''}}) }}

        {% if new_mode|default(false) %}
            {% include 'components/_new_form_intro.html.twig' %}
        {% endif %}

        <fieldset class="space-y-4 p-6 bg-white rounded-lg shadow-inner border border-gray-200">
            <legend class="text-xl font-semibold mb-4 text-gray-900">{{ 'expense.information'|trans }}</legend>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.spentAt, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.spentAt, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-gray-50 text-gray-900'}}) }}
                    {{ form_errors(form.spentAt, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
                </div>
                <div>
                    {{ form_label(form.category, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.category, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-gray-50 text-gray-900'}}) }}
                    {{ form_errors(form.category, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
                </div>
            </div>

            <div>
                {{ form_label(form.label, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(form.label, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-gray-50 text-gray-900 placeholder-gray-400'}}) }}
                {{ form_errors(form.label, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    {{ form_label(form.amount, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.amount, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-gray-50 text-gray-900'}}) }}
                    {{ form_errors(form.amount, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
                </div>
                <div>
                    {{ form_label(form.currency, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.currency, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-gray-50 text-gray-900'}}) }}
                    {{ form_errors(form.currency, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
                </div>
                <div>
                    {{ form_label(form.supplier, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.supplier, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-gray-50 text-gray-900 placeholder-gray-400'}}) }}
                    {{ form_errors(form.supplier, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
                </div>
            </div>

            <div>
                {{ form_label(form.notes, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(form.notes, {'attr': {'class': 'mt-1 w-full rounded-md border-gray-300 bg-gray-50 text-gray-900'}}) }}
                {{ form_errors(form.notes, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
            </div>
        </fieldset>

        <div class="{{ new_mode|default(false) ? 'hidden' : 'flex justify-end mt-6' }}">
            <button class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg shadow-md btn-mobile">
                {{ 'actions.save'|trans }}
            </button>
        </div>

        {{ form_end(form) }}

        {% if new_mode|default(false) %}
            {% include 'components/_new_form_actions.html.twig' with {cancel_route: 'app_expense_index', form_id: form.vars.id} %}
        {% elseif button_label is defined %}
            <div class="flex flex-col sm:flex-row gap-3 mt-4">
                <a href="{{ path('app_expense_index') }}"
                   class="px-4 py-2 bg-[#223044] hover:bg-[#2E415B] rounded text-white btn-mobile">← {{ 'actions.back_to_list'|trans }}</a>

                {{ include('expense/_delete_form.html.twig', {expense: expense}) }}
            </div>
        {% else %}
            <a href="{{ path('app_expense_index') }}"
               class="px-4 py-2 bg-[#223044] hover:bg-[#2E415B] rounded text-white mt-4 inline-block">← {{ 'actions.back_to_list'|trans }}</a>
        {% endif %}
    </div>
</div>
