<form method="post" action="{{ path('app_expense_delete', {'id': expense.id}) }}" onsubmit="return confirm('{{ 'expense.delete_confirm'|trans }}');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ expense.id) }}">
    <button class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded font-semibold btn-mobile">
        {{ 'actions.delete'|trans }}
    </button>
</form>
