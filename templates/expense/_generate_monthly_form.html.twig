<form method="post" action="{{ path('app_expense_generate_monthly', {'id': expense.id}) }}" class="inline-flex flex-wrap items-center gap-2">
    <input type="hidden" name="_token" value="{{ csrf_token('generate_monthly' ~ expense.id) }}">
    <label class="sr-only" for="expense-generate-months-{{ expense.id }}">{{ 'expense.generate_months'|trans }}</label>
    <select
        id="expense-generate-months-{{ expense.id }}"
        name="months"
        class="rounded border border-gray-300 bg-white px-2 py-1.5 text-xs font-semibold text-gray-700"
    >
        <option value="3">3</option>
        <option value="6">6</option>
        <option value="12" selected>12</option>
    </select>
    <button type="submit" class="rounded bg-emerald-100 px-3 py-1.5 text-xs font-semibold text-emerald-800 transition hover:bg-emerald-200">
        {{ 'expense.generate_next_months'|trans }}
    </button>
</form>
