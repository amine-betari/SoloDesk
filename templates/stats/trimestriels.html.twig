{% extends 'base.html.twig' %}

{% block body %}
    <details class="group relative bg-gray-900 border border-gray-700 rounded-xl p-6 mb-8">

        <summary class="flex cursor-pointer list-none flex-col gap-3 pe-0 sm:pe-40">
            <h1 class="text-2xl font-bold text-gray-100">
                {{ 'stats.quarter_title'|trans({'%year%': anneeSelectionnee}) }}
            </h1>

            <div class="space-y-1 text-sm">
                <div>
                    <span class="text-gray-400">{{ 'stats.ca_total'|trans }}</span>
                    <span class="text-blue-300 font-semibold ms-1">
                        {{ caGlobalTexte }}
                    </span>
                </div>
                {% if legalForm == 'AE' and gainGlobalTexte is not null %}
                    <div>
                        <span class="text-gray-400">{{ 'stats.gain_total'|trans }}</span>
                        <span class="text-emerald-300 font-semibold ms-1">
                            {{ gainGlobalTexte }}
                        </span>
                    </div>
                {% endif %}

                <div class="mt-3 h-px bg-gray-700"></div>

                <div>
                    <span class="text-gray-400">{{ 'stats.ca_year'|trans({'%year%': anneeSelectionnee}) }}</span>
                    <span class="text-green-400 font-bold ms-1">
                        {{ caAnneeTexte }}
                    </span>
                </div>
                {% if legalForm == 'AE' and gainAnneeTexte is not null %}
                    <div class="mt-2 ms-4 border-s border-green-700/70 ps-3">
                        <div class="flex flex-wrap gap-x-2 text-xs text-gray-400">
                            <span>{{ 'stats.ca_year_breakdown_gain'|trans }}</span>
                            <span class="font-semibold text-emerald-300">{{ gainAnneeTexte }}</span>
                        </div>
                        {% if gainDetails %}
                        <ul class="mt-1 space-y-1 text-xs">
                            <li class="flex flex-wrap gap-x-2 text-gray-400">
                                <span>{{ 'stats.gain_externals'|trans }}</span>
                                <span class="font-semibold text-amber-300">{{ gainDetails.externes }}</span>
                            </li>
                            <li class="flex flex-wrap gap-x-2 text-gray-400">
                                <span>{{ 'stats.gain_prestations'|trans }}</span>
                                <span class="font-semibold text-sky-300">{{ gainDetails.prestations }}</span>
                            </li>
                        </ul>
                        {% endif %}
                    </div>
                {% endif %}

                <div>
                    <span class="text-gray-400">{{ 'stats.ca_prev_year'|trans({'%year%': anneeSelectionnee - 1}) }}</span>
                    <span class="text-gray-300 ms-1">
                        {{ caAnneePrecedenteTexte }}
                    </span>
                </div>

            </div>
            <span class="absolute bottom-6 right-6 rounded-full border border-gray-600 px-3 py-1 text-xs font-semibold text-gray-300 group-open:hidden">
                {{ 'stats.show_summary'|trans }}
            </span>
            <span class="absolute bottom-6 right-6 hidden rounded-full border border-gray-600 px-3 py-1 text-xs font-semibold text-gray-300 group-open:inline-flex">
                {{ 'stats.hide_summary'|trans }}
            </span>
        </summary>

        <!-- Select année -->
        <form method="get" class="mt-4 flex items-center gap-2 sm:absolute sm:right-6 sm:top-6 sm:mt-0">
            <label for="annee" class="text-gray-400 text-sm">
                {{ 'stats.year'|trans }}
            </label>
            <select name="annee" id="annee" onchange="this.form.submit()"
                    class="bg-gray-800 text-gray-100 border border-gray-600 rounded-md px-3 py-2
                       focus:outline-none focus:ring-2 focus:ring-blue-500 transition">
                {% for y in annees %}
                    <option value="{{ y }}" {% if y == anneeSelectionnee %}selected{% endif %}>
                        {{ y }}
                    </option>
                {% endfor %}
            </select>
        </form>

        <div class="mt-5 hidden border-t border-gray-700 pt-4 text-sm group-open:block">
            <div class="flex flex-wrap gap-3">
                <span class="rounded-full bg-amber-500/10 px-3 py-1 font-semibold text-amber-300">
                    {{ 'stats.best_year'|trans }} {{ bestYearTexte }}
                </span>
                {% if bestYearEstimatedGainTexte is not null %}
                    <span class="rounded-full bg-emerald-500/10 px-3 py-1 font-semibold text-emerald-300">
                        {{ 'stats.best_year_estimated_gain'|trans }} {{ bestYearEstimatedGainTexte }}
                    </span>
                {% endif %}
            </div>

            <div class="mt-4">
                <div class="mb-2 text-xs uppercase tracking-wider text-gray-500">
                    {{ 'stats.annual_revenue_details'|trans }}
                </div>
                <div class="flex flex-wrap gap-2">
                    {% for annualRevenue in annualRevenueDetails %}
                        <span class="rounded-full bg-gray-800 px-3 py-1 text-xs font-semibold text-gray-300">
                            {{ annualRevenue }}
                        </span>
                    {% else %}
                        <span class="text-gray-500">{{ 'common.dash'|trans }}</span>
                    {% endfor %}
                </div>
            </div>
        </div>
    </details>
    <div class="mt-4 h-px bg-gray-700"></div>

    {% if charts is empty %}
        <div class="bg-gray-900 border border-gray-700 p-6 rounded-xl text-gray-300">
            {{ 'stats.no_data'|trans({'%year%': anneeSelectionnee}) }}
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {% for quarter, chart in charts %}
                <div class="bg-gray-900 border border-gray-700 p-6 rounded-xl shadow">
                    <h2 class="text-lg font-semibold mb-4 text-gray-100">
                        {{ quarter }}
                    </h2>

                    <div class="flex-1">
                        {{ render_chart(chart) }}
                    </div>

                    {% set ratios = ratiosParTrimestre[quarter] ?? {'impots': '0', 'cnss': '0'} %}
                    <div class="mt-4 text-sm text-gray-400">
                        <span class="text-yellow-300 font-semibold">{{ 'stats.taxes'|trans({'%rate%': taxImpotRateLabel}) }}:</span>
                        <span class="text-gray-100 ms-1">{{ ratios.impots }}</span>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

{% endblock %}
