{% extends 'base.html.twig' %}

{% block title %}{{ 'client.list_title'|trans }}{% endblock %}

{% block body %}
    <div class="w-full px-6 py-8">
        <div class="space-y-6">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <h1 class="text-3xl sm:text-4xl font-bold text-white">{{ 'client.title'|trans }}</h1>
                    <p class="text-sm text-gray-400 mt-2">{{ 'client.subtitle'|trans }}</p>
                </div>
                <div class="flex items-center gap-3">
                    <a href="{{ path('app_client_new') }}"
                       class="inline-flex items-center justify-center px-5 py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold rounded-lg transition-colors btn-mobile">
                        {{ 'client.new'|trans }}
                    </a>
                </div>
            </div>

            <div class="bg-[#1F2732] border border-[#2A3747] rounded-2xl p-4">
                <form method="get" class="grid grid-cols-1 md:grid-cols-3 gap-3">
                    <input type="text"
                           name="q"
                           value="{{ q }}"
                           placeholder="{{ 'client.search_placeholder'|trans }}"
                           class="w-full rounded-md border border-[#2A3747] bg-[#111922] text-gray-100 placeholder-gray-500 px-4 py-2" />
                    <select name="country" class="w-full rounded-md border border-[#2A3747] bg-[#111922] text-gray-100 px-4 py-2">
                        <option value="">{{ 'client.filter_country'|trans }}</option>
                        {% for availableCountry in countries %}
                            <option value="{{ availableCountry }}" {{ country == availableCountry ? 'selected' : '' }}>{{ availableCountry }}</option>
                        {% endfor %}
                    </select>
                    <select name="currency" class="w-full rounded-md border border-[#2A3747] bg-[#111922] text-gray-100 px-4 py-2">
                        <option value="">{{ 'client.filter_currency'|trans }}</option>
                        {% for availableCurrency in currencies %}
                            <option value="{{ availableCurrency }}" {{ currency == availableCurrency ? 'selected' : '' }}>{{ availableCurrency }}</option>
                        {% endfor %}
                    </select>
                    <div class="flex gap-2 md:col-span-3">
                        <button class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-md btn-mobile">{{ 'actions.search'|trans }}</button>
                        {% if q or country or currency %}
                            <a href="{{ path('app_client_index') }}"
                               class="px-4 py-2 bg-[#223044] hover:bg-[#2E415B] text-white font-semibold rounded-md btn-mobile">{{ 'actions.reset'|trans }}</a>
                        {% endif %}
                    </div>
                </form>
            </div>

            <div class="rounded-2xl border border-[#2A3747] bg-[#1F2732] p-5">
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <div>
                        <div class="text-xs uppercase tracking-wider text-gray-400">{{ 'client.count_total'|trans }}</div>
                        <div class="mt-2 text-2xl font-semibold text-white">{{ pagination.total }}</div>
                    </div>
                    <div>
                        <div class="text-xs uppercase tracking-wider text-gray-400">{{ 'client.count_shown'|trans }}</div>
                        <div class="mt-2 text-2xl font-semibold text-white">{{ pagination.items|length }}</div>
                    </div>
                    <div>
                        <div class="text-xs uppercase tracking-wider text-gray-400">{{ 'common.page'|trans }}</div>
                        <div class="mt-2 text-2xl font-semibold text-white">{{ pagination.page }} / {{ pagination.pages }}</div>
                    </div>
                </div>
            </div>

            {% if pagination.items is not empty %}
                <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white shadow-lg">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'client.table_name'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 hidden md:table-cell">{{ 'client.table_country'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 hidden md:table-cell">{{ 'client.currency'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 hidden lg:table-cell">{{ 'client.table_first_contact'|trans }}</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ 'table.actions'|trans }}</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                        {% for client in pagination.items %}
                            <tr class="hover:bg-gray-50 transition-colors cursor-pointer"
                                tabindex="0"
                                role="link"
                                onclick="if (!event.target.closest('a, button, summary, details')) window.location.href='{{ path('app_client_show', {'id': client.id}) }}'"
                                onkeydown="if ((event.key === 'Enter' || event.key === ' ') && !event.target.closest('a, button, summary, details')) { event.preventDefault(); window.location.href='{{ path('app_client_show', {'id': client.id}) }}'; }">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-gray-100 text-gray-800 flex items-center justify-center font-semibold">
                                            {{ client.name ? client.name|slice(0, 1)|upper : '?' }}
                                        </div>
                                        <div class="min-w-0">
                                            <a href="{{ path('app_client_show', {'id': client.id}) }}"
                                               class="text-sm font-semibold text-gray-900 hover:text-blue-600 transition-colors">
                                                {{ client.name }}
                                            </a>
                                            <div class="text-xs text-gray-500 truncate max-w-[260px]">{{ client.email ?: ('client.email_empty'|trans) }}</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600 hidden md:table-cell">{{ client.country ?: 'common.dash'|trans }}</td>
                                <td class="px-6 py-4 text-sm text-gray-600 hidden md:table-cell">{{ client.currency }}</td>
                                <td class="px-6 py-4 text-sm text-gray-600 hidden lg:table-cell">
                                    {{ client.firstContactAt ? client.firstContactAt|date('d/m/Y') : 'common.dash'|trans }}
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <details class="relative">
                                        <summary class="list-none inline-flex cursor-pointer items-center gap-2 px-3 py-1.5 text-xs font-semibold rounded bg-gray-100 text-gray-700 hover:bg-gray-200 transition">{{ 'table.actions'|trans }}</summary>
                                        <div class="absolute right-0 mt-2 z-10 w-44 rounded-lg border border-gray-200 bg-white shadow-lg p-2">
                                            <a href="{{ path('app_client_edit', {'id': client.id}) }}"
                                               class="block px-3 py-2 rounded bg-blue-600 text-white text-xs font-semibold hover:bg-blue-700">{{ 'actions.edit'|trans }}</a>
                                        </div>
                                    </details>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="px-6 py-10 text-center text-gray-400">{{ 'client.none'|trans }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>

                <div class="flex flex-wrap items-center justify-between gap-4">
                    <p class="text-sm text-gray-400">
                        {{ 'client.pagination'|trans({'%count%': pagination.items|length, '%total%': pagination.total}) }}
                    </p>
                    <div class="flex flex-wrap gap-2">
                        {% for i in 1..pagination.pages %}
                            <a href="?page={{ i }}{% if q %}&q={{ q|url_encode }}{% endif %}{% if country %}&country={{ country|url_encode }}{% endif %}{% if currency %}&currency={{ currency|url_encode }}{% endif %}"
                               class="px-3 py-1.5 rounded-lg text-sm font-medium {{ i == pagination.page ? 'bg-blue-600 text-white' : 'bg-[#223044] text-gray-200 hover:bg-[#2E415B]' }}">
                                {{ i }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% else %}
                <div class="rounded-2xl border border-dashed border-[#2A3747] bg-[#111922] p-10 text-center">
                    <p class="text-gray-400 mb-4">{{ 'client.none'|trans }}</p>
                    <a href="{{ path('app_client_new') }}"
                       class="inline-flex items-center justify-center px-5 py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold rounded-lg transition-colors btn-mobile">
                        {{ 'client.create_first'|trans }}
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
