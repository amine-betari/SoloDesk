{% if canDelete|default(true) %}
    <form method="post" action="{{ path('app_skill_delete', {'id': skill.id}) }}" onsubmit="return confirm('{{ 'skill.delete_confirm'|trans }}');" class="w-full">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ skill.id) }}">
        <button class="w-full px-3 py-2 rounded bg-red-600 text-white text-xs font-semibold hover:bg-red-700 transition">
            {{ 'actions.delete'|trans }}
        </button>
    </form>
{% else %}
    <button type="button"
            disabled
            title="{{ 'skill.delete_used_help'|trans }}"
            class="w-full cursor-not-allowed px-3 py-2 rounded bg-gray-200 text-gray-500 text-xs font-semibold">
        {{ 'actions.delete'|trans }}
    </button>
{% endif %}
